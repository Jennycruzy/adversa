# ─── AXL Mesh ──────────────────────────────────────────────────────────────────
AXL_NODE_PORT=9002
AXL_PRIVATE_KEY_PATH=./keys/agent-private.pem
AXL_CONFIG_PATH=./config/node-config.json

# ─── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=
GITHUB_TOKEN=

# ─── 0G Compute (TEE-verified inference) ──────────────────────────────────────
# OG_PRIVATE_KEY: EVM wallet private key (0x...) that pays for inference via A0GI
# OG_COMPUTE_PROVIDER_ADDRESS: pin a specific TeeML provider address (auto-discovered if blank)
# Ledger is auto-created with OG_LEDGER_INITIAL_BALANCE A0GI on first run.
# If available balance drops below OG_LEDGER_LOW_BALANCE_THRESHOLD, it auto-tops-up
# by OG_LEDGER_DEPOSIT_AMOUNT A0GI. Default: initial=1, deposit=0.5, threshold=0.1
#
# Contract addresses — these are the 0G testnet (chain 16602) values.
# Only override if you are pointing at a different network or custom deployment.
#   OG_LEDGER_CONTRACT_ADDRESS:    ZGComputeNetworkBroker ledger contract
#   OG_INFERENCE_CONTRACT_ADDRESS: ZGComputeNetworkBroker inference contract
OG_PRIVATE_KEY=
OG_RPC_URL=https://evmrpc-testnet.0g.ai
OG_COMPUTE_PROVIDER_ADDRESS=
OG_LEDGER_CONTRACT_ADDRESS=0x815B93ab4Ba4BDF530dbF1552649a3c534F8BbF7
OG_INFERENCE_CONTRACT_ADDRESS=0x41bD7Ac5c19000A974D5c192bcd5FB67b56C85c5
OG_LEDGER_INITIAL_BALANCE=1
OG_LEDGER_DEPOSIT_AMOUNT=0.5
OG_LEDGER_LOW_BALANCE_THRESHOLD=0.1

# ─── 0G Storage ────────────────────────────────────────────────────────────────
OG_STORAGE_INDEXER_URL=https://indexer-storage-testnet-turbo.0g.ai

# ─── 0G Chain Contracts (filled after deployment) ──────────────────────────────
ADVERSA_REGISTRY_ADDRESS=
ADVERSA_REPUTATION_ADDRESS=
ADVERSA_INFT_ADDRESS=
DEPLOYER_PRIVATE_KEY=

# ─── KeeperHub ─────────────────────────────────────────────────────────────────
# KEEPERHUB_API_KEY: REST API key from https://app.keeperhub.com (prefix: kh_)
#   Used for direct REST API calls to https://app.keeperhub.com/api
#   Auth header format: Authorization: Bearer kh_...
# KEEPERHUB_MCP_API_KEY: API key for the local KeeperHub MCP server (usually same as API key)
#   MCP server provides AI-friendly tools: create_workflow, execute_workflow, etc.
#   Start with: docker run -p 3000:3000 -e KEEPERHUB_API_KEY=$KEEPERHUB_API_KEY keeperhub-mcp
#   Integration auto-detects: tries MCP server first, falls back to direct REST API
KEEPERHUB_API_KEY=
KEEPERHUB_MCP_API_KEY=
KEEPERHUB_MCP_PORT=3000
KEEPERHUB_MCP_URL=http://localhost:3000

# ─── Agent Configuration ───────────────────────────────────────────────────────
AGENT_ROLE=gateway
CONSENSUS_THRESHOLD=7500
HUMAN_TIMEOUT_MS=300000

# ─── Dashboard ─────────────────────────────────────────────────────────────────
DASHBOARD_PORT=3001
DASHBOARD_HOST=0.0.0.0

# ─── Offline Mode ──────────────────────────────────────────────────────────────
OFFLINE_QUEUE_PATH=./data/offline-queue.json
CONNECTIVITY_CHECK_INTERVAL_MS=5000

# ─── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
